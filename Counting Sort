public class CountingSort {

    public static void main(String[] args) {
        int arr[] = {4, 2, 2, 8, 3, 3, 1};

        int max = arr[0];
        for (int x : arr)
            if (x > max)
                max = x;

        int count[] = new int[max + 1];

        for (int x : arr)
            count[x]++;

        System.out.println("Sorted Certification IDs:");

        for (int i = 0; i <= max; i++)
            while (count[i]-- > 0)
                System.out.print(i + " ");
    }
}
